 _SM_L   "r.x=sin(n(y*.5,.3)*4.14)*.25+.25;" \
 _SM_L   "r.y=n(y*.73,.3);" \
 _SM_L   "z=mod(y*2.,15.);" \
 _SM_L   "r.z=-smoothstep(0.,.5,z)*smoothstep(.6,.5,z)*.5;" \
 _SM_L   "i.z-=r.z;" \
 _SM_L   "r.y=r.z;" \
 _SM_L   "float u=smoothstep(.4,.6,z)*smoothstep(.8,.6,z)*.8;" \
 _SM_L   "r.z+=u;" \
 _SM_L   "r.w=u;" \
 _SM_L   "a.x=smoothstep(.4,.8,z);" \
 _SM_L   "if(mod(y*2.,30.)>=15.)" \
 _SM_L     "a.x=1.-a.x;" \
 _SM_L   "o=vec3(0);" \
 _SM_L   "for(int v=0;v<2;v++)" \
 _SM_L     "d[v]=vec4(-20),c[v]=vec4(0);" \
 _SM_L   "u=e(w,S,x);" \
 _SM_L   "for(int v=0;v<2;v++)" \
 _SM_L     "for(int f=0;f<4;f++)" \
 _SM_L       "{" \
 _SM_L         "float x=0.,y=d[v][f];" \
 _SM_L         "if(y<0.)" \
 _SM_L           "continue;" \
 _SM_L         "vec3 m=w+S*y,z=e(m,e(y)),i=n(m,z,x);" \
 _SM_L         "o+=e(i,m,z,S,y,x)*c[v][f];" \
 _SM_L       "}" \
 _SM_L   "z=smoothstep(1.9,0.,a.y);" \
 _SM_L   "S=mix(n(iChannel2,S,128.),n(iChannel3,S,64.)*.7,z);" \
 _SM_L   "o+=S*S*SUN_COLOUR*(1.-u);" \
 _SM_L   "o=e(o,f)*smoothstep(0.,2.,iTime);" \
 _SM_L   "v=vec4(o,1);" \
 _SM_L "}" \

#define SHADER_STRING_fxaa_frag \
 _SM_L "#version 150\n" \
       "" \
 _SM_L SHADER_MINIFIER_LINE("#line 396") \
 _SM_L "out vec4 w;" \
 _SM_L "const vec2 S=vec2(1920,1080);" \
 _SM_L "uniform sampler2D o;" \
 _SM_L "void main()" \
 _SM_L "{" \
 _SM_L   "vec2 v=1./S,x=gl_FragCoord.xy*v;" \
 _SM_L   "vec4 f=vec4(x,x-v*.5);" \
 _SM_L   "vec3 y=vec3(.299,.587,.114);" \
 _SM_L   "float z=dot(textureLod(o,f.zw,0.).xyz,y),m=dot(textureLod(o,f.zw+vec2(1,0)*v.xy,0.).xyz,y),i=dot(textureLod(o,f.zw+vec2(0,1)*v.xy,0.).xyz,y),s=dot(textureLod(o,f.zw+vec2(1)*v.xy,0.).xyz,y),t=dot(textureLod(o,f.xy,0.).xyz,y);" \
 _SM_L   "x=vec2(-z-m+i+s,z+i-m-s);" \
 _SM_L   "float a=1./(min(abs(x.x),abs(x.y))+1./128.);" \
 _SM_L   "x=min(vec2(8),max(vec2(-8),x*a))*v.xy;" \
 _SM_L   "vec3 c=.5*(textureLod(o,f.xy+x*(1./3.-.5),0.).xyz+textureLod(o,f.xy+x*(2./3.-.5),0.).xyz),e=c*.5+.25*(textureLod(o,f.xy+x*-.5,0.).xyz+textureLod(o,f.xy+x*.5,0.).xyz);" \
 _SM_L   "a=dot(e,y);" \
 _SM_L   "w=a<min(t,min(min(z,m),min(i,s)))||a>max(t,max(max(z,m),max(i,s)))?" \
 _SM_L     "vec4(c,1):" \
 _SM_L     "vec4(e,1);" \
 _SM_L "}" \

#define SHADER_STRING_heart_frag \
 _SM_L SHADER_MINIFIER_LINE("#line 417") \
 _SM_L "uniform float v;" \
 _SM_L "uniform vec2 x;" \
 _SM_L "uniform vec4 l;" \
 _SM_L "void main()" \
 _SM_L "{" \
 _SM_L   "vec2 f=(2.*gl_FragCoord.xy-x)/x.y;" \
 _SM_L   "float y=mod(v,2.)/2.,m=pow(y,.2)*.5+.5;" \
 _SM_L   "m-=m*.2*sin(y*6.2831*5.)*exp(-y*6.);" \
 _SM_L   "f*=vec2(.5,1.5)+m*vec2(.5,-.5);" \
