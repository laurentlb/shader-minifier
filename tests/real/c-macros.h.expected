 _SM_L   "m=length(f);" \
 _SM_L   "y=abs(y);" \
 _SM_L   "y=(13.*y-22.*y*y+10.*y*y*y)/(6.-5.*y);" \
 _SM_L   "gl_FragColor=vec4(step(m,y)*pow(1.-m/y,.25),0,0,1);" \
 _SM_L "}" \

