                         "r=mix(.5+.5*cos(vec3(.8,.3,2)*(b+1.)),vec3(1),step(min(min(min(min(min(min(min(min(min(min(min(min(min(min(min(min(min(m(vec4(1.54,.53,.91,.72),w),m(vec4(.63,.78,.91,.72),w)),m(vec4(.61,1.675,.72,.64),w)),m(vec4(2.7,3.11,.72,.64),w)),m(vec4(3.45,3.65,.72,.64),w)),m(vec4(4.71,5.02,.72,.64),w)),m(vec4(5.3,5.51,.72,.64),w)),m(vec4(5.96,6.43,.72,.64),w)),m(vec4(3.2,1.27,.45,.35),w)),m(vec4(1.3,2.3,.45,.35),w)),m(vec4(2.58,4.2,.45,.35),w)),m(vec4(3.2,3.95,.35,.25),w)),m(vec4(5.2,5.93,.35,.25),w)),m(vec4(7.9,8.15,.35,.25),w)),m(vec4(.2,1.16,.32,.17),w)),max(length(w)-.84,-length(w)+.72)),max(length(w)-.52,-length(w)+.45)),max(length(w)-.17,-length(w)+.08)),0.))*vec3(1,1,.8)*(smoothstep(.1,.2,s.x)*smoothstep(.1,.2,s.y));"
                         "i+=a*3.*r;"
                         "f=vec3(.1);"
                       "}"
                   "}"
                 "}"
             "}"
           "if(b.y>3.&&b.y<3.2)"
             "f=vec3(.4);"
           "a*=f;"
           "l=d+s*2e-4;"
           "v=r;"
           "x=true;"
         "}"
       "else"
         "{"
           "vec3 f=c>1.5?"
             "vec3(1,.02,.2):"
             "c>.5?"
               "vec3(.2,1,.02):"
               "vec3(.02,.2,1);"
           "if(m()>mix(.2,1.,w))"
             "{"
               "if(b.y>1.5)"
                 "f=vec3(.02);"
               "a*=f;"
               "l=d+s*2e-4;"
               "v=r;"
               "x=true;"
             "}"
           "else"
             "{"
               "if(x)"
                 "break;"
               "a*=b.y>1.5?"
                 "vec3(.5):"
                 ".9*mix(f,vec3(1),.25);"
               "l=d+s*2e-4;"
               "v=reflect(v,s)+(vec3(m(),m(),m())-.5)*.4;"
             "}"
         "}"
       "if(max(a.x,max(a.y,a.z))<.001)"
         "break;"
     "}"
   "return i;"
 "}"
 "void main()"
 "{"
   "vec3 l=vec3(0);"
   "for(int x=0;x<16;++x)"
     "{"
       "y=float(x)+gl_TexCoord[0].x*16.;"
       "float a=m()*6.28319;"
       "vec2 w=vec2(cos(a),sin(a))*sqrt(1.-sqrt(1.-m()))*1.2;"
       "if(int(y)%4==0)"
         "w*=15.*length(w);"
       "l+=v(vec3((gl_FragCoord.xy-vec2(960,540)+w)/540.,-3.5))/48.;"
     "}"
   "l/=(l+1.)/2.;"
   "gl_FragColor.xyz=pow(l+.01*vec3(1,1,.5),vec3(1./2.2))+m()/1e2;"
 "}";

#endif // THE_REAL_PARTY_IS_IN_YOUR_POCKET_FRAG_EXPECTED_
