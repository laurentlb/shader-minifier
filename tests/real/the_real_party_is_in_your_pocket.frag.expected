                         "i=mix(.5+.5*cos(vec3(.8,.3,2)*(w+1.)),vec3(1),step(min(min(min(min(min(min(min(min(min(min(min(min(min(min(min(min(min(n(vec4(1.54,.53,.91,.72),s),n(vec4(.63,.78,.91,.72),s)),n(vec4(.61,1.675,.72,.64),s)),n(vec4(2.7,3.11,.72,.64),s)),n(vec4(3.45,3.65,.72,.64),s)),n(vec4(4.71,5.02,.72,.64),s)),n(vec4(5.3,5.51,.72,.64),s)),n(vec4(5.96,6.43,.72,.64),s)),n(vec4(3.2,1.27,.45,.35),s)),n(vec4(1.3,2.3,.45,.35),s)),n(vec4(2.58,4.2,.45,.35),s)),n(vec4(3.2,3.95,.35,.25),s)),n(vec4(5.2,5.93,.35,.25),s)),n(vec4(7.9,8.15,.35,.25),s)),n(vec4(.2,1.16,.32,.17),s)),max(length(s)-.84,-length(s)+.72)),max(length(s)-.52,-length(s)+.45)),max(length(s)-.17,-length(s)+.08)),0.))*vec3(1,1,.8)*(smoothstep(.1,.2,l.x)*smoothstep(.1,.2,l.y));"
                         "y+=a*3.*i;"
                         "x=vec3(.1);"
                       "}"
                   "}"
                 "}"
             "}"
           "if(w.y>3.&&w.y<3.2)"
             "x=vec3(.4);"
           "a*=x;"
           "v=e+s*2e-4;"
           "m=r;"
           "l=true;"
         "}"
       "else"
         "{"
           "vec3 x=c>1.5?"
             "vec3(1,.02,.2):"
             "c>.5?"
               "vec3(.2,1,.02):"
               "vec3(.02,.2,1);"
           "if(n()>mix(.2,1.,i))"
             "{"
               "if(w.y>1.5)"
                 "x=vec3(.02);"
               "a*=x;"
               "v=e+s*2e-4;"
               "m=r;"
               "l=true;"
             "}"
           "else"
             "{"
               "if(l)"
                 "break;"
               "a*=w.y>1.5?"
                 "vec3(.5):"
                 ".9*mix(x,vec3(1),.25);"
               "v=e+s*2e-4;"
               "m=reflect(m,s)+(vec3(n(),n(),n())-.5)*.4;"
             "}"
         "}"
       "if(max(a.x,max(a.y,a.z))<.001)"
         "break;"
     "}"
   "return y;"
 "}"
 "void main()"
 "{"
   "vec3 y=vec3(0);"
   "for(int x=0;x<16;++x)"
     "{"
       "m=float(x)+gl_TexCoord[0].x*16.;"
       "float l=n()*6.28319;"
       "vec2 s=vec2(cos(l),sin(l))*sqrt(1.-sqrt(1.-n()))*1.2;"
       "if(int(m)%4==0)"
         "s*=15.*length(s);"
       "y+=v(vec3((gl_FragCoord.xy-vec2(960,540)+s)/540.,-3.5))/48.;"
     "}"
   "y/=(y+1.)/2.;"
   "gl_FragColor.xyz=pow(y+.01*vec3(1,1,.5),vec3(1./2.2))+n()/1e2;"
 "}";

#endif // THE_REAL_PARTY_IS_IN_YOUR_POCKET_FRAG_EXPECTED_
