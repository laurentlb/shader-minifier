[numthreads(8,8,1)]
void main(uint3 DTID:SV_DispatchThreadID)
{
  uint2 Dimensions;
  Final.GetDimensions(Dimensions.x,Dimensions.y);
  const bool HasAlbedo=IInput0.x!=0,HasAlpha=IInput1.x!=0,HasRoughness=IInput2.x!=0,HasMetallic=IInput3.x!=0,HasAO=IInput4.x!=0,HasNormalmap=IInput5.x!=0;
  float3 rayPos=float3(0.,2.,6.);
  float sceneFar=20.;
  matrix viewToWorld=viewMatrix(rayPos,float3(0.,0.,0.),float3(0.,1.,0.));
  float3 viewDir=rayDirection(45.,float2(Dimensions.xy),float2(DTID.xy)),rayDir=normalize(mul(float4(viewDir.xyz,0.),viewToWorld)).xyz,lightVector=normalize(float3(.5,2.,.5));
  viewDir=float3(1.,1.,1.);
  SceneHit Hit=traceSDF(rayPos,rayDir,0.,sceneFar,.0025);
  float3 Color=float3(0.,0.,0.);
  if(Hit.tm<sceneFar)
    {
      float3 pW=rayPos+rayDir*Hit.tm,nN=normalSDF(pW,.005),Albedo=float3(.25,.25,.25);
      float Specular=.5,ao=1.,metallic=0.,roughness=1.,skyIntensity=.15;
      float3 CameraVector=rayDir;
      if(Hit.id==0)
        {
          float2 UV=float2(-atan2(nN.z,nN.x)/M_PI*2.,-asin(nN.y)/M_PI*2.);
          if(HasAlbedo)
            Albedo=TInput0.SampleLevel(smpLnWrap,UV,0.).xyz;
          if(HasNormalmap)
            {
              float3 tN=TInput2.SampleLevel(smpLnWrap,UV,0.).xyz*2.-1.,Tg=calculateTangent(nN),Bn=normalize(cross(nN,Tg));
              nN=normalize(Tg.xyz*tN.x+Bn.xyz*tN.y+nN.xyz*tN.z);
            }
          if(HasRoughness||HasMetallic||HasAO)
            {
              float3 RMAO=TInput1.SampleLevel(smpLnWrap,UV,0.).xyz;
              roughness=HasRoughness?
                RMAO.x:
                roughness;
              metallic=HasMetallic?
                RMAO.y:
                metallic;
              ao=HasAO?
                RMAO.z:
                ao;
            }
        }
      else
         roughness=.8,skyIntensity=.5;
      float3 SpecularColor=lerp(.08*Specular,Albedo,metallic),DiffuseColor=Albedo-Albedo*metallic,V=-CameraVector;
      Albedo=nN;
      nN=2.*dot(V,Albedo)*Albedo-V;
      CameraVector=skyColor(nN,lightVector,roughness);
      Color+=CameraVector*envBRDFApprox(SpecularColor,roughness,saturate(dot(Albedo,V)))*ao*skyIntensity;
      CameraVector=traceSoftShadow(pW,lightVector,.01,sceneFar/4.);
      Specular=ao;
      pW=lightVector;
      ao=saturate((dot(Albedo,pW)+.5)/1.5);
      Color+=viewDir*(ao*Specular*CameraVector)*orenNayarShading(DiffuseColor,SpecularColor,max(roughness,.04),pW,V,Albedo,true);
    }
  else
     Color=skyColor(rayDir,lightVector);
  Color=LinearTosRGB(Color);
  Final[DTID.xy]=float4(Color.x,Color.y,Color.z,1.);
  return;
}
